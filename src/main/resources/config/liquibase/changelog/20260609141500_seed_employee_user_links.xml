        </update>

        <update tableName="employee">
            <column name="user_id" valueNumeric="5"/>
            <column name="scoped_warehouse_id" valueNumeric="1"/>
            <column name="department_id" valueNumeric="1"/>
            <where>id = 3 AND user_id IS NULL</where>
        </update>

        <update tableName="employee">
            <column name="user_id" valueNumeric="6"/>
            <column name="scoped_warehouse_id" valueNumeric="1"/>
            <column name="department_id" valueNumeric="8"/>
            <where>id = 4 AND user_id IS NULL</where>
        </update>

        <update tableName="employee">
